*.ckpt
*.gguf
*.bin
*.pt
*.pth
*.apk
*.7z

# ---- Archives (keep the repo lean) ----
*.zip

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db

# runtime logs / delegation dump
*.jsonl
dump/
