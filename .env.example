# Copy this file to ".env" and fill in real keys. council.py loads it via python-dotenv.
# LiteLLM reads these provider keys from these exact variable names.

ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=...

# Moonshot / Kimi: council.py passes this explicitly (it uses the openai-compatible route).
MOONSHOT_API_KEY=...

# Local LM Studio needs no real key — council.py sends a dummy ("lm-studio").
# Just make sure LM Studio's local server is running (default http://localhost:1234/v1).
